# Copy to .env and adjust. Values here are safe local-dev defaults.

# ---- Postgres ----
POSTGRES_USER=stabil
POSTGRES_PASSWORD=stabil
POSTGRES_DB=stabil
# Host dev (apps on host): use localhost. In docker-compose the API uses host "postgres".
DATABASE_URL=postgresql://stabil:stabil@localhost:5432/stabil?schema=public

# ---- Redis (queues, Phase 2+) ----
REDIS_URL=redis://localhost:6379

# ---- MinIO (S3-compatible object storage) ----
MINIO_ROOT_USER=stabil
MINIO_ROOT_PASSWORD=stabilsecret
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_DOCUMENTS=stabil-documents
MINIO_BUCKET_REPORTS=stabil-reports

# ---- Auth (JWT) ----
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# ---- AI parsing via OpenRouter (Phase 2) ----
# Get a key at https://openrouter.ai/keys. Prefer models with no-training/zero-retention
# data policies since resume/ID PII is sent to the provider.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- API ----
PORT=3001

# ---- Web ----
# Server-side (Next) calls the API at API_URL; the browser uses NEXT_PUBLIC_API_URL.
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
