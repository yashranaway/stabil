# Copy to .env and adjust. Values here are safe local-dev defaults.

# ---- Postgres ----
POSTGRES_USER=stabil
POSTGRES_PASSWORD=stabil
POSTGRES_DB=stabil
# Stabil uses a dedicated host-port range (5xxxx) so it never collides with other
# local stacks. Inside docker-compose, services talk over the internal ports.
DATABASE_URL=postgresql://stabil:stabil@localhost:55432/stabil?schema=public

# ---- Redis (queues, Phase 2+) ----
REDIS_URL=redis://localhost:56379

# ---- MinIO (S3-compatible object storage) ----
MINIO_ROOT_USER=stabil
MINIO_ROOT_PASSWORD=stabilsecret
MINIO_ENDPOINT=http://localhost:59000
# Public endpoint used to mint presigned URLs the browser can reach (in compose this
# differs from MINIO_ENDPOINT, which is the internal docker hostname).
MINIO_PUBLIC_ENDPOINT=http://localhost:59000
MINIO_BUCKET_DOCUMENTS=stabil-documents
MINIO_BUCKET_REPORTS=stabil-reports

# ---- Auth (JWT) ----
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# ---- Email (notifications) ----
# Leave SMTP_URL empty in dev — emails are logged via a JSON transport.
SMTP_URL=
EMAIL_FROM=Stabil <no-reply@stabil.dev>

# ---- AI parsing via OpenRouter (Phase 2) ----
# Get a key at https://openrouter.ai/keys. Prefer models with no-training/zero-retention
# data policies since resume/ID PII is sent to the provider.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- API ----
# The API process listens on PORT; docker-compose maps it to host :3301.
PORT=3001

# ---- Web ----
# Server-side (Next) calls the API at API_URL; the browser uses NEXT_PUBLIC_API_URL.
# Docker-compose exposes: web :3300, api :3301.
API_URL=http://localhost:3301
NEXT_PUBLIC_API_URL=http://localhost:3301
